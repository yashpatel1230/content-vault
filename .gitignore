# Secrets
.env
.env.local
*.key

# Per-user populated corpora (users fill these in locally)
skills/*/corpus.md
skills/*/seed-accounts.md
skills/*/reference-corpus.md

# Don't ignore the .example templates
!skills/*/corpus.md.example
!skills/*/seed-accounts.md.example

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*~

# youtube-publisher: OAuth secrets + per-channel state (never commit these)
**/client_secrets.json
**/token.json
**/uploaded.json
**/finalize-state.json

# youtube-description: generated transcripts
skills/youtube-description/transcripts/

# Python (video-use)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
*.lock

# Node (if anyone adds JS tooling)
node_modules/
npm-debug.log*

# Build artifacts
dist/
build/
out/

# Obsidian: ship the shared vault config, ignore per-user/volatile state
.obsidian/workspace*
.obsidian/cache

# qmd local search index (per-machine; rebuilt by scripts/qmd-setup.sh)
.qmd/
